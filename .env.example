# ─── Smart Water Tank Monitoring — Environment Variables ─────────────────────

# Server
PORT=3000

# MongoDB Atlas — URI template (password stored separately for privacy)
# Copy this file to .env and fill in your actual values
MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/<DATABASE>?appName=<APP_NAME>
MONGO_PASSWORD=your_mongodb_password_here

# How many records to keep per tank in MongoDB (last N readings)
DB_HISTORY_LIMIT=10